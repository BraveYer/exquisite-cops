# ============================================================
#  Exquisite COPS — BOT (.env la rădăcină)
#  Copiază în `.env` și completează. `.env` e ignorat de git.
# ============================================================

# ===== Discord =====
DISCORD_TOKEN=your-bot-token-here

# Guild (server) + roluri + canale — pune ID-urile tale reale
# (Discord: Developer Mode ON -> click dreapta -> Copy ID)
GUILD_ID=
VERIFIED_ROLE_ID=1486798653397008394
MODERATOR_ROLE_ID=
ADMIN_ROLE_ID=
MATCH_LOG_CHANNEL_ID=1487559983146209511

# ===== Baza de date =====
# Acelasi cluster Atlas (ExquisiteCOPS). String din Atlas -> Connect -> Drivers.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
# Numele bazei logice din cluster (confirma in Atlas -> Data Explorer; default e des "test")
MONGODB_DB=test

# ===== Critical Ops public API =====
COPS_API_URL=https://api-cops.criticalforce.fi/api/public/profile?usernames=
# API-ul cere un User-Agent de browser
COPS_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0 Safari/537.36
